# --- secrets: never commit the real API key ---
.env

# local runtime state / user prefs
config.json

# python caches
__pycache__/
*.pyc

# generated output and logs (keep the empty folders via .gitkeep)
logs/*
!logs/.gitkeep
output/*
!output/.gitkeep
*.scratch*

# --- school content: NEVER public ---
# (keep the empty documents folder, never its contents)
documents/*
!documents/.gitkeep
*.docx
